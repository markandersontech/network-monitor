  "panels": [
    {
      "type": "timeseries",
      "title": "Interface Bandwidth (bps)",
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT derivative(mean(\"ifHCInOctets\"), 1s) * 8 FROM \"interface\" WHERE $timeFilter AND \"hostname\" =~ /^$hostname$/ AND \"ifName\" =~ /^$interface$/ GROUP BY time($__interval), \"ifName\" fill(null)",
          "refId": "A"
        },
        {
          "query": "SELECT derivative(mean(\"ifHCOutOctets\"), 1s) * 8 FROM \"interface\" WHERE $timeFilter AND \"hostname\" =~ /^$hostname$/ AND \"ifName\" =~ /^$interface$/ GROUP BY time($__interval), \"ifName\" fill(null)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "options": {}
    },
    {
      "type": "timeseries",
      "title": "Top Interfaces by Inbound Traffic",
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT top(derivative(mean(\"ifHCInOctets\"), 1s) * 8, \"ifName\", 5) FROM \"interface\" WHERE $timeFilter AND \"hostname\" =~ /^$hostname$/ GROUP BY time($__interval)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "options": {}
    },
    {
      "type": "stat",
      "title": "Device Uptime",
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT last(\"uptime\") FROM \"snmp\" WHERE $timeFilter AND \"hostname\" =~ /^$hostname$/",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ],
  "refresh": "30s",
